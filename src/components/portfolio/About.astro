---

<section id="values" class="py-24 px-8 max-w-7xl mx-auto">
  <div style="border-top: 1px solid #262626;" class="pt-12">
    <div class="flex flex-col lg:flex-row gap-16">
      <div class="lg:w-48 shrink-0">
        <p class="text-xs tracking-widest uppercase" style="color:#b5f23d;">Values</p>
      </div>
      <div class="flex-1 space-y-16">
        {values.map((block, bi) => (
          <div class="animate-in" style={`--stagger: ${bi * 80}ms`}>
            <h2 class="font-black mb-8" style="font-size: clamp(1.5rem, 3vw, 2.25rem); color:#e8e8e8; letter-spacing:-0.02em; line-height:1.2;">
              {block.title}
            </h2>
            <ul class="space-y-5">
              {block.items.map((html) => (
                <li class="flex gap-4" style="color:#888888; font-size:1rem; line-height:1.8;">
                  <span style="color:#444; margin-top:0.1em; flex-shrink:0;">•</span>
                  <p set:html={html} />
                </li>
              ))}
            </ul>
          </div>
        ))}
      </div>
    </div>
  </div>
</section>

<section id="about" class="py-24 px-8 max-w-7xl mx-auto">
  <div style="border-top: 1px solid #262626;" class="pt-12">

    <div class="flex flex-col lg:flex-row gap-16">
      <!-- Left label -->
      <div class="lg:w-48 shrink-0">
        <p class="text-xs tracking-widest uppercase" style="color:#b5f23d;">Experience</p>
      </div>

      <!-- Right content -->
      <div class="flex-1">

        <!-- Experience -->
        <div class="mb-20">
          <p class="text-xs tracking-widest uppercase mb-10" style="color:#555555;">경력</p>

          <div class="space-y-14">
            {experiences.map((exp, i) => (
              <div class="animate-in" style={`--stagger: ${i * 80}ms`}>

                <!-- Company header -->
                <div class="flex items-start gap-4 mb-8">
                  <div
                    class="shrink-0 rounded-2xl overflow-hidden flex items-center justify-center"
                    style="width:72px; height:72px; background:#ffffff; border: 1px solid #e0e0e0;"
                  >
                    <img
                      src={exp.logo}
                      alt={exp.company}
                      class="w-full h-full object-contain p-2"
                    />
                  </div>
                  <div class="flex-1 min-w-0">
                    <div class="flex flex-col sm:flex-row sm:items-baseline sm:justify-between gap-1">
                      <p class="text-lg font-bold" style="color:#e8e8e8;">{exp.company}</p>
                      <p class="text-xs shrink-0" style="color:#555555;">{exp.period}</p>
                    </div>
                    <div class="flex items-center gap-2 mt-0.5">
                      <p class="text-sm" style="color:#888888;">{exp.role}</p>
                      <span style="color:#333;">·</span>
                      <p class="text-xs" style="color:#555555;">{exp.type}</p>
                    </div>
                  </div>
                </div>

                <!-- Projects -->
                <div class="space-y-10 sm:pl-[3.75rem]">
                  {exp.projects.map((proj) => (
                    <div>
                      <!-- Project title row -->
                      <div class="flex flex-wrap items-center gap-2 mb-3">
                        <span
                          class="text-[10px] font-bold tracking-widest uppercase px-2 py-0.5 rounded"
                          style="background:#1e1e1e; color:#b5f23d;"
                        >
                          {proj.category}
                        </span>
                        <p class="text-base font-semibold" style="color:#e8e8e8;">
                          {proj.name}
                        </p>
                      </div>

                      <!-- Description (blockquote) -->
                      <div class="mb-4 pl-4 text-sm" style="border-left: 2px solid #2a2a2a; color:#666666; line-height:1.75;" set:html={proj.desc} />

                      <!-- Tech badges -->
                      <div class="flex flex-wrap gap-1.5 mb-5">
                        {proj.tech.map((t) => (
                          <code
                            class="text-xs px-2 py-0.5 rounded"
                            style="background:#161616; color:#888888; border: 1px solid #252525; font-family: ui-monospace, monospace;"
                          >
                            {t}
                          </code>
                        ))}
                      </div>

                      <!-- Achievements -->
                      <ul class="space-y-2.5 mb-6">
                        {proj.achievements.map((item) => (
                          <li class="flex gap-3 text-sm" style="color:#888888; line-height:1.7;">
                            <span style="color:#b5f23d; flex-shrink:0; margin-top:0.3rem; font-size:0.65rem;">▸</span>
                            <span set:html={item} />
                          </li>
                        ))}
                      </ul>

                      <!-- Technical contributions -->
                      {proj.contributions && proj.contributions.length > 0 && (
                        <div class="space-y-5">
                          {proj.contributions.map((c) => (
                            <div class="pl-4" style="border-left: 2px solid #222;">
                              <p class="text-sm font-semibold mb-1.5" style="color:#c8c8c8;">{c.title}</p>
                              <p class="text-sm" style="color:#666666; line-height:1.8;" set:html={c.body} />
                            </div>
                          ))}
                        </div>
                      )}
                    </div>
                  ))}
                </div>

              </div>
            ))}
          </div>
        </div>

        <!-- Education -->
        <div class="mb-14">
          <p class="text-xs tracking-widest uppercase mb-6" style="color:#555555;">학력</p>
          <div class="flex items-start gap-4">
            <div class="shrink-0 rounded-2xl overflow-hidden flex items-center justify-center"
              style="width:72px; height:72px; background:#f5f5f5; border: 1px solid #e0e0e0;">
              <div class="w-full h-full flex items-center justify-center text-sm font-black" style="color:#1a1a1a;">
                GSM
              </div>
            </div>
            <div class="flex-1 min-w-0">
              <div class="flex flex-col sm:flex-row sm:items-baseline sm:justify-between gap-1">
                <p class="text-lg font-bold" style="color:#e8e8e8;">광주소프트웨어 마이스터고등학교</p>
                <p class="text-xs shrink-0" style="color:#555555;">2020.03 — 2023.01</p>
              </div>
              <p class="text-sm mt-0.5" style="color:#888888;">소프트웨어 개발과 · 졸업</p>
            </div>
          </div>
        </div>

        <!-- Awards -->
        <div class="mb-8">
          <p class="text-xs tracking-widest uppercase mb-4" style="color:#555555;">Awards</p>
          <div class="flex flex-wrap gap-2">
            {[
              '2021 4개교 연합 해커톤 🥇',
              '2021 교내 올림피아드 🥇',
              '2021 KDN SW경진대회 🥉',
              '2020 교내 해커톤 🥈',
            ].map((item) => (
              <span class="tag">{item}</span>
            ))}
          </div>
        </div>

        <!-- Certifications -->
        <div>
          <p class="text-xs tracking-widest uppercase mb-4" style="color:#555555;">Certifications</p>
          <div class="flex flex-wrap gap-2">
            {[
              '정보처리기능사 (2023)',
            ].map((item) => (
              <span class="tag">{item}</span>
            ))}
          </div>
        </div>
      </div>
    </div>

  </div>
</section>
