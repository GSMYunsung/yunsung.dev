---
const groups = [
  {
    label: 'Frontend',
    skills: ['React', 'TypeScript', 'React Native', 'Remix', 'Next.js', 'Tailwind CSS', 'HTML / CSS'],
  },
  {
    label: 'State & Tooling',
    skills: ['Jotai', 'Redux', 'Storybook', 'Webpack5', 'Vite'],
  },
  {
    label: 'Etc',
    skills: ['Git / GitHub', 'jQuery', 'Vanilla JS', 'Pug', 'Figma'],
  },
];
---

<section id="skills" class="py-24 px-8 max-w-7xl mx-auto">
  <div style="border-top: 1px solid #262626;" class="pt-12">

    <div class="flex flex-col lg:flex-row gap-16">
      <!-- Left label -->
      <div class="lg:w-48 shrink-0">
        <p class="text-xs tracking-widest uppercase" style="color:#b5f23d;">Skills</p>
      </div>

      <!-- Right content -->
      <div class="flex-1 space-y-10">
        {groups.map((group, i) => (
          <div class="flex flex-col sm:flex-row gap-6 animate-in" style={`--stagger: ${i * 80}ms`}>
            <p class="text-xs tracking-widest uppercase shrink-0 w-32 mt-1" style="color:#555555;">
              {group.label}
            </p>
            <div class="flex flex-wrap gap-2">
              {group.skills.map((skill) => (
                <span class="tag">{skill}</span>
              ))}
            </div>
          </div>
        ))}
      </div>
    </div>

  </div>
</section>
