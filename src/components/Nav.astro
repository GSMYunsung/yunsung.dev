---
const pathname = Astro.url.pathname;
const isBlog = pathname.startsWith('/blog');

const links = [
  { href: '/#about', label: 'About' },
  { href: '/#experience', label: 'Experience' },
  { href: '/#projects', label: 'Projects' },
  { href: '/blog', label: 'Blog' },
  { href: '/#contact', label: 'Contact' },
];
---

<header
  class="fixed top-0 left-0 right-0 z-50 transition-all"
  id="nav"
  style="background: rgba(15,15,15,0.85); backdrop-filter: blur(12px); border-bottom: 1px solid transparent;"
>
  <nav class="max-w-7xl mx-auto px-8 h-14 flex items-center justify-between">
    <div class="flex items-center gap-2 text-sm font-semibold tracking-tight">
      <a href="/" class="flex items-center gap-2" style="color:#e8e8e8;">
        <span style="color:#b5f23d;">yunsung</span>
        <span style="color:#444;">/</span>
        <span style="color:#888; font-weight:400;">dev</span>
      </a>
      {isBlog && (
        <>
          <span style="color:#333;">/</span>
          <span style="color:#666; font-weight:400;">blog</span>
        </>
      )}
    </div>

    {isBlog ? (
      <!-- Blog: 포트폴리오로 돌아가기 버튼 -->
      <a
        href="/"
        class="blog-back-btn flex items-center gap-1.5 text-xs transition-all"
        style="color:#666; border:1px solid #262626; border-radius:9999px; padding:0.3rem 0.85rem;"
      >
        <svg width="12" height="12" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7"/>
        </svg>
        포트폴리오
      </a>
    ) : (
      <>
        <!-- Desktop -->
        <ul class="hidden md:flex items-center gap-1">
          {links.map((link) => (
            <li>
              <a
                href={link.href}
                class="nav-link px-3 py-1.5 text-sm rounded transition-colors"
                style="color:#888888;"
              >
                {link.label}
              </a>
            </li>
          ))}
        </ul>

        <!-- Mobile button -->
        <button
          id="mobile-menu-btn"
          class="md:hidden p-2 rounded transition-colors"
          style="color:#888888;"
          aria-label="메뉴"
        >
          <svg class="w-5 h-5" id="menu-icon" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M4 6h16M4 12h16M4 18h16" />
          </svg>
          <svg class="w-5 h-5 hidden" id="close-icon" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M6 18L18 6M6 6l12 12" />
          </svg>
        </button>
      </>
    )}
  </nav>

  <!-- Mobile menu (포트폴리오 페이지에서만) -->
  {!isBlog && (
    <div id="mobile-menu" class="hidden md:hidden px-8 pb-4" style="border-top: 1px solid #222;">
      <ul class="flex flex-col gap-1 pt-3">
        {links.map((link) => (
          <li>
            <a
              href={link.href}
              class="block px-3 py-2 text-sm rounded transition-colors"
              style="color:#888888;"
            >
              {link.label}
            </a>
          </li>
        ))}
      </ul>
    </div>
  )}
</header>

<div class="h-14"></div>

<style>
  .nav-link:hover { color: #e8e8e8 !important; }
  #nav.scrolled { border-bottom-color: #222 !important; }
  .blog-back-btn:hover { color: #b5f23d !important; border-color: #b5f23d !important; }
</style>

<script>
  const btn = document.getElementById('mobile-menu-btn');
  const menu = document.getElementById('mobile-menu');
  const menuIcon = document.getElementById('menu-icon');
  const closeIcon = document.getElementById('close-icon');

  btn?.addEventListener('click', () => {
    const isOpen = !menu?.classList.contains('hidden');
    menu?.classList.toggle('hidden', isOpen);
    menuIcon?.classList.toggle('hidden', !isOpen);
    closeIcon?.classList.toggle('hidden', isOpen);
  });

  menu?.querySelectorAll('a').forEach((a) => {
    a.addEventListener('click', () => {
      menu.classList.add('hidden');
      menuIcon?.classList.remove('hidden');
      closeIcon?.classList.add('hidden');
    });
  });

  const nav = document.getElementById('nav');
  window.addEventListener('scroll', () => {
    nav?.classList.toggle('scrolled', window.scrollY > 10);
  });
</script>
