---
const year = new Date().getFullYear();
---

<footer class="px-8 py-8 w-full max-w-7xl mx-auto" style="border-top: 1px solid #1e1e1e;">
  <div class="flex flex-col sm:flex-row items-start sm:items-center justify-between gap-4">
    <span class="text-sm font-semibold" style="color:#b5f23d;">yunsung</span>
    <p class="text-xs" style="color:#444444;">© {year} 최윤성. Built with Astro & Tailwind CSS.</p>
    <div class="flex items-center gap-5">
      {[
        { label: 'GitHub', href: 'https://github.com/GSMYunsung' },
        { label: 'Email', href: 'mailto:12345ggh81@gmail.com' },
      ].map((link) => (
        <a href={link.href}
          target={link.href.startsWith('http') ? '_blank' : undefined}
          rel="noopener noreferrer"
          class="text-xs transition-colors"
          style="color:#444444;"
          onmouseover="this.style.color='#b5f23d'" onmouseout="this.style.color='#444444'">
          {link.label}
        </a>
      ))}
    </div>
  </div>
</footer>
