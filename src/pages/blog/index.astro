---
import { getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';

const allPosts = await getCollection('blog', ({ data }) => !data.draft);
const posts = allPosts.sort((a, b) => {
  if (a.data.featured && !b.data.featured) return -1;
  if (!a.data.featured && b.data.featured) return 1;
  return b.data.pubDate.valueOf() - a.data.pubDate.valueOf();
});

const categories = ['전체', 'Frontend', 'Backend', 'DevOps', 'AI', '생산성', '기타'] as const;

const catStyle: Record<string, string> = {
  Frontend: 'color:#60a5fa; background:#0d1f33; border:1px solid #1a3a5c;',
  Backend:  'color:#4ade80; background:#0d2218; border:1px solid #1a3d26;',
  DevOps:   'color:#fb923c; background:#281a0a; border:1px solid #4a2e0e;',
  AI:       'color:#22d3ee; background:#071e26; border:1px solid #0e3440;',
  생산성:   'color:#a78bfa; background:#17122e; border:1px solid #2e1f5e;',
  기타:     'color:#94a3b8; background:#1a1a1a; border:1px solid #2a2a2a;',
};
---

<BaseLayout
  title="블로그 — 최윤성"
  description="개발하면서 배운 것들을 기록합니다."
>
  <section class="mt-24 pb-16 px-8 max-w-7xl mx-auto" style="border-top: 1px solid #262626;">
    <div class="pt-12">
      <div class="flex flex-col lg:flex-row gap-16">

        <div class="lg:w-48 shrink-0">
          <p class="text-xs tracking-widest uppercase" style="color:#b5f23d;">Blog</p>
          <p id="post-count" class="mt-2 text-xs" style="color:#444444;">총 {posts.length}개의 글</p>
        </div>

        <div class="flex-1">

          <!-- Search + Filter -->
          <div class="flex flex-col sm:flex-row gap-3 mb-10 flex-wrap">
            <div class="relative">
              <svg class="absolute left-3 top-1/2 -translate-y-1/2 w-3.5 h-3.5" style="color:#555555;" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0"/>
              </svg>
              <input
                type="text"
                id="search-input"
                placeholder="글 검색..."
                style="padding-left:2rem; padding-right:1rem; padding-top:0.375rem; padding-bottom:0.375rem; font-size:0.8rem; border-radius:9999px; background:#161616; border:1px solid #262626; color:#e8e8e8; outline:none; width:180px;"
              />
            </div>

            <div class="flex gap-1.5 flex-wrap" id="category-tabs">
              {categories.map((cat) => (
                <button
                  data-category={cat}
                  class="category-tab px-3 py-1.5 rounded-full text-xs font-medium transition-all"
                  style={cat === '전체'
                    ? 'background:#b5f23d; color:#0f0f0f; border:none;'
                    : 'background:#161616; color:#888888; border:1px solid #262626;'}
                >
                  {cat}
                </button>
              ))}
            </div>
          </div>

          <!--
            5개 행 × ~128px = 640px 고정 높이.
            숨겨진 행은 display:none이지만 컨테이너 높이가 고정되어
            페이지가 바뀌어도 pagination 위치가 항상 동일.
          -->
          <div id="posts-list" style="height: 640px; overflow: hidden;">
            {posts.map((post) => {
              const { title, description, pubDate, category, tags, featured } = post.data;
              const formattedDate = new Intl.DateTimeFormat('ko-KR', {
                year: 'numeric', month: '2-digit', day: '2-digit',
              }).format(pubDate);
              return (
                <a
                  href={`/blog/${post.id}`}
                  class="post-row flex flex-col sm:flex-row gap-2 sm:gap-8 py-5 group block"
                  style="border-top: 1px solid #1e1e1e; text-decoration:none;"
                  data-category={category}
                  data-title={title.toLowerCase()}
                  data-description={description.toLowerCase()}
                  data-tags={tags.join(' ').toLowerCase()}
                >
                  <div class="flex-1">
                    <div class="flex items-baseline justify-between gap-4 mb-1.5">
                      <div class="flex items-center gap-2 flex-wrap">
                        <p class="text-sm font-semibold" style="color:#e8e8e8;">{title}</p>
                        {featured && (
                          <span class="text-[10px] font-bold tracking-widest uppercase px-2 py-0.5 rounded"
                            style="background:#1e1e1e; color:#b5f23d;">Featured</span>
                        )}
                      </div>
                      <p class="text-xs shrink-0" style="color:#555555;">{formattedDate}</p>
                    </div>
                    <p class="text-sm mb-2.5" style="color:#666666;">{description}</p>
                    <div class="flex flex-wrap gap-2 items-center">
                      <span class="text-xs font-medium px-2 py-0.5 rounded-full" style={catStyle[category] ?? catStyle['기타']}>{category}</span>
                      {tags.slice(0, 3).map((tag) => (
                        <span class="text-xs" style="color:#444444;">#{tag}</span>
                      ))}
                    </div>
                  </div>
                </a>
              );
            })}
          </div>

          <!-- Empty state: overlaps the fixed-height container when no results -->
          <div id="empty-state" class="hidden" style="margin-top:-640px; padding-top:4rem;">
            <p class="text-sm" style="color:#555555;">검색 결과가 없습니다</p>
          </div>

          <!-- Pagination: in flow, always right below the 640px posts block -->
          <div id="pagination" style="display:none; padding-top:6rem; justify-content:center;">
            <div class="flex items-center gap-1" style="background:rgba(15,15,15,0.92); backdrop-filter:blur(12px); border:1px solid #2a2a2a; border-radius:9999px; padding:0.375rem 0.75rem;">
              <button id="prev-btn" class="text-xs px-2.5 py-1.5 rounded-full transition-colors" style="color:#555555; cursor:pointer;">←</button>
              <div id="page-numbers" class="flex gap-0.5"></div>
              <button id="next-btn" class="text-xs px-2.5 py-1.5 rounded-full transition-colors" style="color:#555555; cursor:pointer;">→</button>
            </div>
          </div>

        </div>
      </div>
    </div>
  </section>
</BaseLayout>

<script>
  const PAGE_SIZE = 5;
  let currentPage = 1;
  let activeCategory = '전체';
  let searchQuery = '';

  const tabs        = document.querySelectorAll<HTMLButtonElement>('.category-tab');
  const rows        = Array.from(document.querySelectorAll<HTMLElement>('.post-row'));
  const searchInput = document.getElementById('search-input') as HTMLInputElement;
  const emptyState  = document.getElementById('empty-state')!;
  const pagination  = document.getElementById('pagination')!;
  const prevBtn     = document.getElementById('prev-btn') as HTMLButtonElement;
  const nextBtn     = document.getElementById('next-btn') as HTMLButtonElement;
  const pageNumbers = document.getElementById('page-numbers')!;
  const postCount   = document.getElementById('post-count')!;

  function getMatching() {
    return rows.filter(row => {
      const matchCat = activeCategory === '전체' || row.dataset.category === activeCategory;
      const matchSearch = searchQuery === ''
        || (row.dataset.title ?? '').includes(searchQuery)
        || (row.dataset.description ?? '').includes(searchQuery)
        || (row.dataset.tags ?? '').includes(searchQuery);
      return matchCat && matchSearch;
    });
  }

  function render() {
    const matching = getMatching();
    const totalPages = Math.max(1, Math.ceil(matching.length / PAGE_SIZE));
    currentPage = Math.min(currentPage, totalPages);

    const start = (currentPage - 1) * PAGE_SIZE;
    const visible = new Set(matching.slice(start, start + PAGE_SIZE));

    rows.forEach(row => row.classList.toggle('hidden', !visible.has(row)));

    const isEmpty = matching.length === 0;
    emptyState.classList.toggle('hidden', !isEmpty);

    const showPager = !isEmpty && totalPages > 1;
    pagination.style.display = showPager ? 'flex' : 'none';

    postCount.textContent = isEmpty ? '0개의 글' : `${matching.length}개의 글`;

    if (showPager) {
      prevBtn.style.color  = currentPage <= 1 ? '#333333' : '#888888';
      prevBtn.style.cursor = currentPage <= 1 ? 'default' : 'pointer';
      nextBtn.style.color  = currentPage >= totalPages ? '#333333' : '#888888';
      nextBtn.style.cursor = currentPage >= totalPages ? 'default' : 'pointer';

      // 숫자 버튼 렌더링
      pageNumbers.innerHTML = '';
      for (let p = 1; p <= totalPages; p++) {
        const btn = document.createElement('button');
        btn.textContent = String(p);
        btn.className = 'text-xs px-2.5 py-1.5 rounded transition-colors';
        btn.style.cssText = p === currentPage
          ? 'background:#b5f23d; color:#0f0f0f; font-weight:600; cursor:default;'
          : 'color:#666666; cursor:pointer;';
        btn.addEventListener('mouseover', () => {
          if (p !== currentPage) btn.style.color = '#e8e8e8';
        });
        btn.addEventListener('mouseout', () => {
          if (p !== currentPage) btn.style.color = '#666666';
        });
        btn.addEventListener('click', () => {
          currentPage = p;
          render();
          window.scrollTo({ top: 0, behavior: 'smooth' });
        });
        pageNumbers.appendChild(btn);
      }
    }
  }

  prevBtn.addEventListener('click', () => {
    if (currentPage > 1) { currentPage--; render(); window.scrollTo({ top: 0, behavior: 'smooth' }); }
  });

  nextBtn.addEventListener('click', () => {
    const total = Math.ceil(getMatching().length / PAGE_SIZE);
    if (currentPage < total) { currentPage++; render(); window.scrollTo({ top: 0, behavior: 'smooth' }); }
  });

  tabs.forEach(tab => {
    tab.addEventListener('click', () => {
      activeCategory = tab.dataset.category ?? '전체';
      currentPage = 1;
      tabs.forEach(t => {
        const isActive = t.dataset.category === activeCategory;
        t.style.background = isActive ? '#b5f23d' : '#161616';
        t.style.color      = isActive ? '#0f0f0f' : '#888888';
        t.style.border     = isActive ? 'none'    : '1px solid #262626';
      });
      render();
    });
  });

  searchInput?.addEventListener('input', e => {
    searchQuery = (e.target as HTMLInputElement).value.toLowerCase().trim();
    currentPage = 1;
    render();
  });

  render();
</script>

<style>
  .post-row:hover { background: rgba(255,255,255,0.02); }
  #search-input::placeholder { color: #444444; }
  #search-input:focus { border-color: #b5f23d !important; }
  #prev-btn:hover, #next-btn:hover { color: #e8e8e8 !important; }
</style>
